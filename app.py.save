import tkinter as tk
from tkinter import filedialog, messagebox
from rembg import remove
from PIL import Image
import os


class App:
    def __init__(self, root):
        self.root = root
        self.root.title("Image Background Remover 🧼")
        self.root.geometry("520x280")
        self.root.resizable(False, False)

        self.image_path = ""

        # Título
        self.title = tk.Label(
            root,
            text="🧼 Eliminador de Fondo de Imágenes",
            font=("Arial", 16, "bold")
        )
        self.title.pack(pady=15)

        # Botón seleccionar imagen
        self.btn_select = tk.Button(
            root,
            text="📁 Seleccionar Imagen",
            command=self.select_image,
            width=25,
            height=2
        )
        self.btn_select.pack(pady=5)

        # Ruta seleccionada
        self.path_label = tk.Label(
            root,
            text="Ninguna imagen seleccionada",
            wraplength=450
        )
        self.path_label.pack(pady=5)

        # Botón procesar
        self.btn_process = tk.Button(
            root,
            text="🧼 Eliminar Fondo",
            command=self.process_image,
            width=25,
            height=2,
            bg="#4CAF50",
            fg="white"
        )
        self.btn_process.pack(pady=10)

        # Estado
        self.status = tk.Label(
            root,
            text="",
            fg="blue"
        )
        self.status.pack(pady=10)

    def select_image(self):
        self.image_path = filedialog.askopenfilename(
            title="Seleccionar imagen",
            filetypes=[("Imágenes", "*.png *.jpg *.jpeg")]
        )

        if self.image_path:
            self.path_label.config(text=self.image_path)
            self.status.config(text="Imagen cargada ✔️")

    def process_image(self):
        if not self.image_path:
            messagebox.showwarning("Atención", "Primero seleccioná una imagen")
            return

        try:
            self.status.config(text="Procesando... 🧠🧼")
            self.root.update()

            input_image = Image.open(self.image_path)
            output_image = remove(input_image)

            save_path = os.path.splitext(self.image_path)[0] + "_no_bg.png"
            output_image.save(save_path)

            self.status.config(text="Listo ✔️ Imagen guardada")
            messagebox.showinfo("Éxito", f"Guardado en:\n{save_path}")

        except Exception as e:
            messagebox.showerror("Error", str(e))
            self.status.config(text="Error ❌")


if __name__ == "__main__":
    root = tk.Tk()
    app = App(root    root.mainloop()
